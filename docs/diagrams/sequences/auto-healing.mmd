%% Fluxo: Auto-Healing (Nó Perdido)
%% Referência: docs/blueprint/07-critical_flows.md

sequenceDiagram
    autonumber

    participant Sched as Scheduler<br/>(@nestjs/schedule)
    participant API as Orquestrador<br/>(NestJS)
    participant DB as PostgreSQL 18<br/>(Prisma)
    participant SDK as Core SDK<br/>(ConsistentHashRing)
    participant S3src as StorageProvider<br/>(nó com réplica)
    participant S3dst as StorageProvider<br/>(nó destino)

    %% Detecção
    Sched ->>+ DB: SELECT nodes WHERE last_heartbeat < NOW() - 30min
    DB -->>- Sched: suspect_nodes[]

    loop Para cada nó suspect
        Sched ->>+ DB: UPDATE nodes SET status = 'suspect'
        DB -->>- Sched: OK
        Sched ->> API: Gerar alerta (warning: nó suspect)
    end

    Note over Sched: Aguarda mais 30 min (total 1h)

    Sched ->>+ DB: SELECT nodes WHERE status = 'suspect' AND last_heartbeat < NOW() - 1h
    DB -->>- Sched: lost_nodes[]

    loop Para cada nó lost
        Sched ->>+ DB: UPDATE nodes SET status = 'lost'
        DB -->>- Sched: OK
        Sched ->> API: Gerar alerta (critical: nó lost)

        %% Identificar chunks afetados
        Sched ->>+ DB: SELECT chunk_id FROM chunk_replicas WHERE node_id = lost_node
        DB -->>- Sched: affected_chunks[]

        Sched ->>+ DB: SELECT chunk_id, COUNT(*) FROM chunk_replicas GROUP BY chunk_id HAVING COUNT(*) < 3
        DB -->>- Sched: sub_replicated[]

        loop Para cada chunk sub-replicado
            Sched ->>+ SDK: ConsistentHashRing.select_new_node(chunk, exclude: lost_node)
            SDK -->>- Sched: new_target_node

            %% Copiar de réplica existente
            Sched ->>+ S3src: GET chunk (de nó saudável)
            S3src -->>- Sched: chunk_data

            Sched ->> Sched: Verificar SHA-256 == chunk_id

            alt Hash OK
                Sched ->>+ S3dst: PUT chunk (no novo nó)
                S3dst -->>- Sched: OK

                Sched ->>+ DB: INSERT chunk_replicas + DELETE replica nó lost
                DB -->>- Sched: OK
            else Hash corrompido
                Sched ->> Sched: Tentar próxima réplica
            end
        end

        Sched ->> API: Resolver alerta + relatório auto-healing
    end

    Note over Sched, S3dst: Todos os chunks restaurados com 3 réplicas
