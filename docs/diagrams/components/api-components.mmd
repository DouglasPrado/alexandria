%% C4 Nivel 3: Componentes Internos — Orquestrador Alexandria
%% Referencia: docs/blueprint/06-system_architecture.md
%% Stack: NestJS + Prisma + NestJS Guards middleware

graph TB
    subgraph ContainerBoundary["⚙️ Orquestrador (NestJS) — Componentes Internos"]
        direction TB

        subgraph EntryLayer["Camada de Entrada (NestJS Router)"]
            direction LR
            ClusterRouter["🔀 Cluster API<br/>POST /clusters<br/>POST /clusters/:id/invite<br/>GET /clusters/:id/health"]
            FileRouter["🔀 File API<br/>POST /files/upload<br/>GET /files<br/>GET /files/:id/download"]
            NodeRouter["🔀 Node API<br/>POST /nodes/register<br/>POST /nodes/:id/heartbeat<br/>POST /nodes/:id/drain"]
            AlertRouter["🔀 Alert API<br/>GET /alerts<br/>PATCH /alerts/:id/resolve"]
        end

        Middleware["🛡️ NestJS Guards Middleware<br/>Auth (JWT/Token), TLS validation,<br/>Rate limiting (ThrottlerGuard), Request tracing"]

        subgraph ServiceLayer["Camada de Serviços / Casos de Uso"]
            direction LR
            ClusterService["📋 ClusterService<br/>Criar cluster, gerar seed,<br/>convidar membros, permissões"]
            FileService["📋 FileService<br/>Upload, pipeline orchestration,<br/>deduplicação, status tracking"]
            NodeService["📋 NodeService<br/>Registrar nó, heartbeat,<br/>drain, detecção offline"]
            ReplicationService["📋 ReplicationService<br/>Distribuir chunks, auto-healing,<br/>rebalanceamento, monitoramento"]
            SchedulerService["📋 SchedulerService<br/>Scrubbing, GC, rebalance,<br/>heartbeat timeout, alertas"]
        end

        subgraph DataLayer["Camada de Acesso a Dados (Prisma + PostgreSQL 18)"]
            direction LR
            ClusterRepo["🗃️ ClusterRepository<br/>CRUD clusters + members"]
            FileRepo["🗃️ FileRepository<br/>CRUD files + manifests"]
            ChunkRepo["🗃️ ChunkRepository<br/>CRUD chunks + réplicas"]
            NodeRepo["🗃️ NodeRepository<br/>CRUD nodes + heartbeats"]
            AlertRepo["🗃️ AlertRepository<br/>CRUD alerts"]
        end

        subgraph IntegrationLayer["Camada de Integrações (Core SDK)"]
            direction LR
            StorageClient["🔌 StorageProvider<br/>aws-sdk-s3 adapter<br/>put/get/exists/delete/list"]
            VaultClient["🔌 VaultManager<br/>Encrypt/decrypt vault por membro,<br/>manage credentials"]
            CryptoEngine["🔌 CryptoEngine<br/>aes-gcm, sha2, bip39<br/>Envelope encryption"]
            HashRing["🔌 ConsistentHashRing<br/>Distribuição de chunks,<br/>seleção de nós destino"]
        end
    end

    %% Dependências Externas
    DB[("🗄️ PostgreSQL 18<br/>Metadados")]
    RedisQ["📨 Redis 7<br/>Fila + pub/sub"]
    S3Ext["📦 S3 / R2<br/>Chunk storage"]

    %% Fluxo: Entrada → Middleware
    ClusterRouter --> Middleware
    FileRouter --> Middleware
    NodeRouter --> Middleware
    AlertRouter --> Middleware

    %% Fluxo: Middleware → Serviços
    Middleware --> ClusterService
    Middleware --> FileService
    Middleware --> NodeService
    Middleware --> ReplicationService

    %% Fluxo: Serviços → Repositórios
    ClusterService --> ClusterRepo
    FileService --> FileRepo
    FileService --> ChunkRepo
    NodeService --> NodeRepo
    ReplicationService --> ChunkRepo
    ReplicationService --> NodeRepo
    SchedulerService --> ChunkRepo
    SchedulerService --> NodeRepo
    SchedulerService --> AlertRepo

    %% Fluxo: Serviços → Integrações
    FileService --> CryptoEngine
    FileService --> HashRing
    ReplicationService --> StorageClient
    ReplicationService --> HashRing
    ClusterService --> VaultClient
    ClusterService --> CryptoEngine

    %% Conexões Externas
    ClusterRepo -->|"Prisma"| DB
    FileRepo -->|"Prisma"| DB
    ChunkRepo -->|"Prisma"| DB
    NodeRepo -->|"Prisma"| DB
    AlertRepo -->|"Prisma"| DB
    FileService -->|"TCP (enqueue)"| RedisQ
    SchedulerService -->|"TCP (enqueue)"| RedisQ
    StorageClient -->|"HTTPS (aws-sdk-s3)"| S3Ext

    %% Estilos
