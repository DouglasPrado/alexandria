%% ============================================================
%% Diagrama de Deploy: Produção — Alexandria
%% Referências: docs/blueprint/06-system_architecture.md
%% Stack: Rust + Axum 0.8, Next.js 16, PostgreSQL 17, Redis 7
%% ============================================================

graph TB

    %% ===========================================================
    %% CAMADA: DNS
    %% ===========================================================
    subgraph DNS_LAYER["☁️ DNS"]
        direction LR
        DNS["DNS Provider<br/>──────────<br/>alexandria.domínio<br/>TTL: 300s<br/>A record → IP da VPS"]
    end

    %% ===========================================================
    %% CAMADA: VPS (Servidor Único)
    %% ===========================================================
    subgraph VPS["🖥️ VPS — Hetzner/DigitalOcean (~€5-10/mês)"]
        direction TB

        subgraph PROXY["Reverse Proxy"]
            Caddy["Caddy<br/>──────────<br/>Porta: 443 (HTTPS)<br/>TLS: Let's Encrypt (auto-renew)<br/>Proxy: orquestrador :8080 + web :3000"]
        end

        subgraph APP_TIER["Docker Compose v2 — Application"]
            direction LR
            Orchestrator["Orquestrador<br/>──────────<br/>Runtime: Rust + Axum 0.8<br/>Porta: 8080<br/>CPU: 2 vCPU / RAM: 2GB<br/>Inclui: Scheduler (tokio::time)<br/>+ Media Workers + Vault"]
            WebClient["Web Client<br/>──────────<br/>Runtime: Next.js 16 (Turbopack)<br/>Porta: 3000<br/>CPU: 0.5 vCPU / RAM: 512MB"]
        end

        subgraph DATA_TIER["Docker Compose v2 — Data"]
            direction LR
            DB_PRIMARY["PostgreSQL 17<br/>──────────<br/>Porta: 5432<br/>Driver: SQLx (async)<br/>Volume: /data/postgres<br/>Backup: pg_dump diário → S3"]
            Redis_P["Redis 7<br/>──────────<br/>Porta: 6379<br/>Sem persistência<br/>(jobs são recuperáveis)"]
        end

        FFmpeg_D["FFmpeg 7 + libvips<br/>──────────<br/>Instalado no container<br/>do Orquestrador"]
    end

    %% ===========================================================
    %% CAMADA: Storage Cloud
    %% ===========================================================
    subgraph CLOUD_STORAGE["📦 Cloud Storage (chunks criptografados)"]
        direction LR
        S3_Bucket["AWS S3<br/>──────────<br/>Região: eu-west-1<br/>Classe: S3 Standard<br/>SDK: aws-sdk-s3 (Rust)"]
        R2_Bucket["Cloudflare R2<br/>──────────<br/>Sem egress fees<br/>S3-compatible<br/>SDK: aws-sdk-s3 (Rust)"]
    end

    %% ===========================================================
    %% CAMADA: Nós da Família
    %% ===========================================================
    subgraph FAMILY_NODES["💻 Nós da Família (agentes de nó)"]
        direction LR
        PC["PC/NAS Doméstico<br/>──────────<br/>Agent: Rust binary + Axum<br/>Storage: filesystem local<br/>Heartbeat: 1/min"]
        VPS_Node["VPS Remota<br/>──────────<br/>Agent: Rust binary + Axum<br/>Storage: filesystem<br/>Always-online anchor"]
    end

    %% ===========================================================
    %% CONEXÕES
    %% ===========================================================

    DNS -->|"Resolução DNS"| Caddy
    Caddy -->|"HTTP :8080"| Orchestrator
    Caddy -->|"HTTP :3000"| WebClient

    Orchestrator -->|"SQLx async :5432"| DB_PRIMARY
    Orchestrator -->|"TCP :6379"| Redis_P
    Orchestrator --> FFmpeg_D

    Orchestrator -->|"HTTPS (aws-sdk-s3)"| S3_Bucket
    Orchestrator -->|"HTTPS (aws-sdk-s3)"| R2_Bucket

    DB_PRIMARY -.->|"pg_dump diário"| S3_Bucket

    PC -->|"HTTPS/REST (TLS)<br/>heartbeat + chunks"| Caddy
    VPS_Node -->|"HTTPS/REST (TLS)<br/>heartbeat + chunks"| Caddy

    PC -.->|"DNS lookup"| DNS
    VPS_Node -.->|"DNS lookup"| DNS

    %% ===========================================================
    %% ESTILOS
    %% ===========================================================

    style DNS_LAYER fill:#FFF3E0,stroke:#F5A623,stroke-width:2px,color:#333
    style DNS fill:#F5A623,stroke:#E09100,color:#fff

    style VPS fill:#E3F2FD,stroke:#438DD5,stroke-width:2px,color:#333
    style PROXY fill:#BBDEFB,stroke:#438DD5,stroke-width:1px,color:#333
    style APP_TIER fill:#BBDEFB,stroke:#438DD5,stroke-width:1px,color:#333
    style DATA_TIER fill:#C8E6C9,stroke:#67BE4B,stroke-width:1px,color:#333
    style Caddy fill:#F5A623,stroke:#E09100,color:#fff
    style Orchestrator fill:#438DD5,stroke:#2B6CB0,color:#fff
    style WebClient fill:#438DD5,stroke:#2B6CB0,color:#fff
    style DB_PRIMARY fill:#67BE4B,stroke:#4A9A35,color:#fff
    style Redis_P fill:#67BE4B,stroke:#4A9A35,color:#fff
    style FFmpeg_D fill:#999999,stroke:#6b6b6b,color:#fff

    style CLOUD_STORAGE fill:#F5F5F5,stroke:#999999,stroke-width:2px,color:#333
    style S3_Bucket fill:#999999,stroke:#6b6b6b,color:#fff
    style R2_Bucket fill:#999999,stroke:#6b6b6b,color:#fff

    style FAMILY_NODES fill:#E3F2FD,stroke:#5a9bd5,stroke-width:2px,color:#333
    style PC fill:#5a9bd5,stroke:#3a7bb5,color:#fff
    style VPS_Node fill:#5a9bd5,stroke:#3a7bb5,color:#fff
