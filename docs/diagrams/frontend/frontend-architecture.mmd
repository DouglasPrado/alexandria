%% ============================================================
%% Arquitetura do Frontend — Alexandria
%% Referência: docs/frontend/01-architecture.md
%% ============================================================

graph TD
    subgraph "UI Layer (Server + Client Components)"
        Pages[Pages & Layouts]
        SC[Server Components]
        CC[Client Components]
    end

    subgraph "Application Layer"
        Hooks[Custom Hooks]
        TQ[TanStack Query]
        Zustand[Zustand Stores]
    end

    subgraph "Domain Layer"
        Models[Models & Types]
        Rules[Business Rules]
        Interfaces[Interfaces]
    end

    subgraph "Infrastructure Layer"
        API[API Client - fetch]
        Auth[Auth Interceptor - JWT]
        Cache[Local Storage]
    end

    Pages --> SC
    Pages --> CC
    SC --> TQ
    CC --> Hooks
    Hooks --> TQ
    Hooks --> Zustand
    TQ --> API
    Zustand --> Models
    API --> Auth
    API -.->|implements| Interfaces
    Auth --> Models

    subgraph "Features (Dominios)"
        F1[auth]
        F2[cluster]
        F3[gallery]
        F4[upload]
        F5[nodes]
        F6[health]
        F7[recovery]
        F8[settings]
    end

    Pages --> F1 & F2 & F3 & F4 & F5 & F6 & F7 & F8

    subgraph "Backend (Orquestrador)"
        NestJS[NestJS REST API]
        PG[(PostgreSQL)]
        Redis[(Redis)]
    end

    API -->|HTTPS/TLS 1.3| NestJS
    NestJS --> PG
    NestJS --> Redis
