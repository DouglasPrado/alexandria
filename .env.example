# ===================================
# Alexandria — Environment Variables
# ===================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o .env — apenas .env.example.

# --- Database ---
DATABASE_URL="postgresql://alexandria:alexandria@localhost:5432/alexandria?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- JWT Auth ---
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING"
JWT_EXPIRES_IN="24h"
REFRESH_TOKEN_EXPIRES_IN="7d"

# --- Crypto ---
# Nenhuma variavel — seed phrase gera master key em memoria

# --- Email (Resend) ---
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@alexandria.local"

# --- Storage Providers (configurados via vault, nao via env) ---
# Credenciais S3/R2/B2 sao armazenadas no vault criptografado do admin

# --- App ---
NODE_ENV="development"
PORT=3333
LOG_LEVEL="debug"
CORS_ORIGIN="http://localhost:3000"
WEB_CLIENT_URL="http://localhost:3000"
API_BASE_URL="http://localhost:3333/api"
OAUTH_STATE_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING"


# --- Web Client ---
NEXT_PUBLIC_API_URL="http://localhost:3333/api"
