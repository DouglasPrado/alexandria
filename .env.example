# Alexandria — Environment Variables

# PostgreSQL
DATABASE_URL=postgres://alexandria:alexandria@localhost:5432/alexandria

# Redis
REDIS_URL=redis://localhost:6379

# Server
HOST=0.0.0.0
PORT=8080

# Logging (trace, debug, info, warn, error)
RUST_LOG=alexandria=info,tower_http=debug

# TLS (production only)
# TLS_CERT_PATH=/etc/caddy/certs/cert.pem
# TLS_KEY_PATH=/etc/caddy/certs/key.pem

# Storage providers (configure in member vault, not here)
# AWS_REGION=us-east-1
# AWS_ENDPOINT_URL=https://s3.amazonaws.com
