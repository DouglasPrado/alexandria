# Alexandria — Environment Variables
# Copie para .env e ajuste os valores.

# ─── PostgreSQL ────────────────────────────────────────
POSTGRES_USER=alexandria
POSTGRES_PASSWORD=alexandria
POSTGRES_DB=alexandria
DATABASE_URL=postgres://alexandria:alexandria@localhost:5432/alexandria

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Orchestrator ──────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# ─── Logging (trace, debug, info, warn, error) ────────
RUST_LOG=alexandria=info,tower_http=info

# ─── Auth ──────────────────────────────────────────────
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32

# ─── Node auto-registration ────────────────────────────
BOOTSTRAP_TOKEN=change-me-generate-with-openssl-rand-hex-32

# ─── Node Agent (apenas para node-agent) ───────────────
# NODE_ID=<uuid do no registrado no orchestrator>
# ORCHESTRATOR_URL=http://localhost:8080
# STORAGE_PATH=/data/alexandria
# MAX_CAPACITY_GB=100
# NODE_PORT=9090
# HEARTBEAT_INTERVAL_SECS=60

# ─── Domain (producao — descomentar e configurar) ─────
# DOMAIN=alexandria.example.com

# ─── Storage S3/R2 (configurado via vault, nao aqui) ──
# AWS_REGION=us-east-1
# AWS_ENDPOINT_URL=https://s3.amazonaws.com
