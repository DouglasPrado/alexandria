# Alexandria API — Environment Variables
# Copy to .env and fill values: cp .env.example .env

# PostgreSQL (required)
DATABASE_URL="postgresql://alexandria:alexandria@localhost:5432/alexandria?schema=public"

# Redis (required)
REDIS_URL="redis://localhost:6379"

# JWT (required)
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING"

# Email — Resend (optional in dev)
RESEND_API_KEY=""

# App
NODE_ENV="development"
PORT=3333
LOG_LEVEL="debug"
WEB_CLIENT_URL="http://localhost:3000"
API_BASE_URL="http://localhost:3333/api"
OAUTH_STATE_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING"

# OAuth cloud nodes (phase 2)
GOOGLE_DRIVE_CLIENT_ID=""
GOOGLE_DRIVE_CLIENT_SECRET=""
ONEDRIVE_CLIENT_ID=""
ONEDRIVE_CLIENT_SECRET=""
DROPBOX_CLIENT_ID=""
DROPBOX_CLIENT_SECRET=""
