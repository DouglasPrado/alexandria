{
  "name": "alexandria",
  "version": "0.1.0",
  "private": true,
  "description": "Distributed family storage system — preserve memories for decades",
  "license": "MIT",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "test:e2e": "turbo test:e2e",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "turbo typecheck",
    "db:migrate": "pnpm --filter @alexandria/api prisma migrate deploy",
    "db:migrate:dev": "pnpm --filter @alexandria/api prisma migrate dev",
    "db:generate": "pnpm --filter @alexandria/api prisma generate",
    "db:studio": "pnpm --filter @alexandria/api prisma studio",
    "db:seed": "pnpm --filter @alexandria/api prisma db seed",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
